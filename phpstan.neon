includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon

parameters:
    paths:
        - app/
        - tests/Unit/
    level: 8
    treatPhpDocTypesAsCertain: false
    # app/* ignoreErrors need the full project scan; partial paths (e.g. tests/Unit only) would otherwise fail.
    reportUnmatchedIgnoredErrors: false
    excludePaths:
        - app/Providers/
    ignoreErrors:
        # PHPUnit: assert* are intentionally static on Assert::
        -
            identifier: staticMethod.dynamicCall
            path: tests/Unit/*
        # Spatie Media Library conversion methods are called via __call
        - '#Call to an undefined method Spatie\\Image\\Drivers\\ImageDriver::nonQueued#'
        # Eloquent dynamic scopes and methods via __call
        - '#Dynamic call to static method Illuminate\\Database\\Eloquent\\Builder<.*>::(published|draft|count|limit|latest|simplePaginate|with)\(\)#'
        # DOMDocument iteration returns DOMElement but typed as DOMNode
        - '#DOMNameSpaceNode\|DOMNode#'
        # Eloquent model dynamic properties accessed in Filament table closures
        - '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::\$published_at#'
        # Filament afterStateHydrated: $record is null on create pages, nullsafe is intentional
        - identifier: nullsafe.neverNull
          path: app/Filament/Resources/*/Schemas/*Form.php
