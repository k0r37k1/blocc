{
  // https://github.com/DavidAnson/markdownlint-cli2
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",
  "config": {
    "extends": "./.markdownlint.json"
  },
  "globs": [
    "README.md",
    "SECURITY.md",
    "documentation/**/*.md"
  ],
  "ignores": [
    "node_modules/**",
    "vendor/**",
    "storage/**",
    "public/build/**",
    ".cursor/**",
    ".claude/**",
    "CLAUDE.md",
    "AGENTS.md"
  ]
}
